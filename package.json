  "type": "module",
  "description": "DB UX Design System - Astro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/astro.git"
  },
  "bugs": {
    "url": "https://github.com/db-ux-design-system/astro/issues"
  },
  "author": "DB Systel GmbH",
  "license": "Apache-2.0",
  "private": true,
  "keywords": [
    "astro",
    "deutsche-bahn"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "eslint && prettier --check . && pnpm -r lint",
    "format": "prettier --write .",
