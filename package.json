    "test": "pnpm -r test",
    "dev": "pnpm dev:astro",
    "preview": "pnpm preview:astro",
    "dev:astro": "pnpm --filter test-app-astro dev",
    "preview:astro": "pnpm --filter test-app-astro preview"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
